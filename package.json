{
	"name": "antigravity-super-sentinel",
	"displayName": "Antigravity Super Sentinel",
	"description": "Live agent dashboard, smart auto-clicker, and session telemetry for Google Antigravity IDE.",
	"version": "2.5.0",
	"publisher": "IKadzura",
	"license": "MIT",
	"icon": "media/icon.png",
	"keywords": [
		"antigravity",
		"agent",
		"dashboard",
		"automation",
		"auto-click",
		"telemetry",
		"session",
		"quota",
		"AI",
		"productivity"
	],
	"galleryBanner": {
		"color": "#0d0d0d",
		"theme": "dark"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kasuganozomi/super-sentinel-antigravity-IDE-extension.git"
	},
	"bugs": {
		"url": "https://github.com/kasuganozomi/super-sentinel-antigravity-IDE-extension/issues"
	},
	"homepage": "https://github.com/kasuganozomi/super-sentinel-antigravity-IDE-extension#readme",
	"engines": {
		"vscode": "^1.60.0"
	},
	"extensionKind": [
		"workspace"
	],
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./src/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "antigravity-super-sentinel-container",
					"title": "Super Sentinel",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"antigravity-super-sentinel-container": [
				{
					"type": "webview",
					"id": "antigravity-super-sentinel-view",
					"name": "Sentinel Dashboard",
					"icon": "media/icon.svg"
				}
			]
		},
		"commands": [
			{
				"command": "antigravity-super-sentinel.enable",
				"title": "Antigravity Super Sentinel: Enable (Inject Script)"
			},
			{
				"command": "antigravity-super-sentinel.disable",
				"title": "Antigravity Super Sentinel: Disable (Remove Script)"
			},
			{
				"command": "antigravity-super-sentinel.toggle",
				"title": "Antigravity Super Sentinel: Toggle ON/OFF"
			},
			{
				"command": "antigravity-super-sentinel.openSettings",
				"title": "Antigravity Super Sentinel: Open Dashboard"
			}
		],
		"configuration": {
			"title": "Antigravity Super Sentinel",
			"properties": {
				"antigravity-super-sentinel.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable or disable Auto Click and Auto Scroll"
				},
				"antigravity-super-sentinel.scrollEnabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable or disable Auto Scroll"
				}
			}
		}
	}
}
